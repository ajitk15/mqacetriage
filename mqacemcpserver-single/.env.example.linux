# =============================================================================
# Composites-only MQ + ACE MCP server — environment variables
# Target environment: Linux (Red Hat Enterprise Linux / RHEL 8+, also CentOS
# Stream, Rocky, Alma).
#
# This is the Linux/RHEL variant of .env.example. This build is a SIBLING
# server to the root mqacemcpserver. It exposes 6 composite tools (one tool per
# common diagnostic intent) so a client that can only invoke ONE tool per user
# turn can still complete discovery-plus-execution workflows in a single call.
#
# Copy to `.env` and fill in real values:
#     cp .env.example.linux .env
# Do NOT commit `.env`.
#
# By default this build reads the same CSV manifests as the root server from
# `../resources/`. Override RESOURCES_DIR (or the individual paths) below if
# your deployment splits them.
#
# RHEL deployment notes:
#   * Use forward-slash POSIX paths. ~ and $VAR expand for LOG_DIR / TLS paths.
#   * Bind ports < 1024 only as root or with CAP_NET_BIND_SERVICE; otherwise
#     keep the high ports below.
#   * SELinux is enforcing by default — label logs/certs placed outside the
#     deploy tree so the service can read/write them.
# =============================================================================

# -----------------------------------------------------------------------------
# MCP server (transport, bind address, optional Basic Auth on SSE)
# -----------------------------------------------------------------------------
# Transport: "stdio" (local/dev) or "sse" (HTTP endpoint for the central team).
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
# Own port for this build so it can run side-by-side with the main MCP server
# (which uses 8009). 8010 avoids the other repo ports (backend 8002, frontend
# 8003, dashboard 8004). Use 443 only where the process can bind privileged
# ports (root / CAP_NET_BIND_SERVICE).
MCP_PORT=8010

# Optional Basic Auth on the SSE endpoint. Both must be set to enable.
# Has no effect on stdio transport.
MCP_AUTH_USER=mcpadmin
MCP_AUTH_PASSWORD=change-me

# Optional TLS for the SSE endpoint. BOTH cert and key must be set to enable
# HTTPS; otherwise the server falls back to plain HTTP. Paths support ~ and
# $VAR expansion. Use unencrypted PEM-format files.
# Has no effect on stdio transport.
# RHEL convention is /etc/pki/tls; a repo-relative ../certs/ dir also works
# (relative paths resolve against the repo root, the parent of this directory).
MCP_TLS_CERT=/etc/pki/tls/certs/mqacemcpserver.pem
MCP_TLS_KEY=/etc/pki/tls/private/mqacemcpserver.key

# Logging level. One of DEBUG/INFO/WARNING/ERROR.
MQACE_LOG_LEVEL=INFO

# Directory for application + per-call query logs. Created at startup. Kept
# separate from the main build's logs so Power BI can ingest them as a distinct
# dataset. On RHEL, /var/log is the convention; ensure the service user owns it.
LOG_DIR=/var/log/mqacemcpserver-single

# Days to retain rotated log files. Older files are removed on startup.
LOG_RETENTION_DAYS=30

# Set to false to disable the per-call user query log (queries-YYYY-MM-DD.jsonl).
QUERY_LOG_ENABLED=true

# -----------------------------------------------------------------------------
# Resource (CSV manifest) locations
# -----------------------------------------------------------------------------
# Defaults to ../resources/ (the parent repo's resources/ folder) so the
# external extract jobs continue to feed both servers from one location.
# Override the directory or any individual file if your deployment splits them.
RESOURCES_DIR=../resources
MQ_QMGR_DUMP_PATH=../resources/qmgr_dump.csv
ACE_NODE_DUMP_PATH=../resources/node_dump.csv
ACE_NODE_CONFIG_PATH=../resources/node_config.csv
CERT_DUMP_PATH=../resources/cert_dump.csv

# -----------------------------------------------------------------------------
# IBM MQ — REST API endpoint, credentials, safety
# -----------------------------------------------------------------------------
# Base URL of any one MQ web (mqweb) server. Hostname will be substituted per-call
# for cross-host operations. Trailing slash required.
# Example: https://mqhost.example.com:9443/ibmmq/rest/v2/admin/
MQ_URL_BASE=https://localhost:9443/ibmmq/rest/v3/admin/
MQ_USER_NAME=mqreader
MQ_PASSWORD=change-me

# Comma-separated hostname prefixes that this server is permitted to talk to.
# Matched case-insensitively against the start of the hostname. Anything else
# is blocked with a friendly message. Excludes production by convention.
MQ_ALLOWED_HOSTNAME_PREFIXES=lod,loq,lot,loc,lop

# Display strings used in the "modification blocked" message.
MQ_SUPPORT_TEAM=MQ Infra Support
MQ_ADMIN_GROUP=MQACE_ADMIN

# -----------------------------------------------------------------------------
# IBM App Connect Enterprise (ACE) — REST API credentials, safety
# -----------------------------------------------------------------------------
# ACE Admin REST API uses host:port from resources/node_config.csv per node.
# Credentials are shared across nodes; leave blank if the API is unauthenticated.
ACE_USER_NAME=acereader
ACE_PASSWORD=change-me

# Same allow-list model as MQ. Matched against the host column of node_config.csv.
ACE_ALLOWED_HOSTNAME_PREFIXES=lod,loq,lot,loc

# -----------------------------------------------------------------------------
# Splunk — read-only log search for triage / root-cause
# -----------------------------------------------------------------------------
# REST/search API base of the Splunk search head (splunkd management port,
# 8089 by default — NOT the web UI port). Basic Auth creds mirror the MQ
# namespace; use a least-privilege search-only Splunk role.
SPLUNK_URL_BASE=https://localhost:8089
SPLUNK_USER=
SPLUNK_PASSWORD=

# Index names the canned MQ/ACE error searches target. Must match where the
# Universal Forwarder lands MQ error logs and ACE syslog/event logs. These are
# deployment-specific — set them to your actual index names.
SPLUNK_MQ_INDEX=ibmmq
SPLUNK_ACE_INDEX=ibm_ace

# Same allow-list model as MQ/ACE — applied to the SPLUNK_URL_BASE hostname.
SPLUNK_ALLOWED_HOSTNAME_PREFIXES=localhost,lod,loq,lot

# -----------------------------------------------------------------------------
# Dynatrace — read-only historical performance trends / problems
# -----------------------------------------------------------------------------
# SaaS environment URL + a classic API token (Authorization: Api-Token <token>)
# with scopes metrics.read, entities.read, problems.read. Tools error until set.
# Example URL: https://abc12345.live.dynatrace.com
DYNATRACE_URL_BASE=
DYNATRACE_API_TOKEN=

# Allow-list for the Dynatrace host. EMPTY blocks all calls — Dynatrace SaaS is
# external, so add your environment host prefix (e.g. the env-id "abc12345").
DYNATRACE_ALLOWED_HOSTNAME_PREFIXES=

# Metric selectors (comma-separated keys). Host metrics use stable builtin:*
# defaults. MQ/ACE component keys are deployment-specific (depend on the
# installed extension) — discover them with dynatrace_list_metrics, then set them.
DYNATRACE_HOST_METRIC_SELECTORS=builtin:host.cpu.usage,builtin:host.mem.usage,builtin:host.disk.usedPct,builtin:host.cpu.load
DYNATRACE_MQ_METRIC_SELECTORS=
DYNATRACE_ACE_METRIC_SELECTORS=
