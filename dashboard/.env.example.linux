# =============================================================================
# Log-insights dashboard — environment variables
# Target environment: Linux (Red Hat Enterprise Linux / RHEL 8+, also CentOS
# Stream, Rocky, Alma).
#
# This is the Linux/RHEL variant of .env.example. Standalone HTTP server that
# renders the MQ+ACE query-log dashboard.
#
# IMPORTANT: dashboard_server.py does NOT load this file. It reads
# MCP_DASHBOARD_HOST / MCP_DASHBOARD_PORT / MCP_SERVER_DIR from the process
# environment, and gets LOG_DIR + TLS from the build named by MCP_SERVER_DIR
# (that build's server.config loads ITS own .env). This file's role:
#   - The scripts/start-all.* launchers read MCP_DASHBOARD_PORT from here and
#     inject it (with MCP_SERVER_DIR for the build they launched) into the
#     dashboard process.
#   - To make the other values below take effect when you run the server BARE
#     (not via start-all), export them into the environment first — copying the
#     file alone does nothing, since nothing auto-loads it. On RHEL, e.g.:
#         set -a; . ./.env; set +a
#         python dashboard/dashboard_server.py
#
# Copy to `.env` and adjust as needed:
#     cp .env.example.linux .env
# Do NOT commit `.env`. Use forward-slash POSIX paths.
# =============================================================================

# -----------------------------------------------------------------------------
# Dashboard bind settings
# -----------------------------------------------------------------------------
# Bind address and port for the standalone dashboard HTTP server.
# Defaults if unset: host=0.0.0.0, port=8002. Endpoints: /dashboard, /healthz.
# Use 8004 to avoid colliding with the chat backend (8002) and Streamlit (8003).
# Bind ports < 1024 only as root or with CAP_NET_BIND_SERVICE.
MCP_DASHBOARD_HOST=0.0.0.0
MCP_DASHBOARD_PORT=8004

# -----------------------------------------------------------------------------
# MCP server directory override
# -----------------------------------------------------------------------------
# By default the dashboard imports `server.config` / `server.logger` from
# `../mqacemcpserver/`. Override to point at the single-build's server package.
MCP_SERVER_DIR=../mqacemcpserver-single

# -----------------------------------------------------------------------------
# Shared config (provided by the imported build's `server.config`)
# -----------------------------------------------------------------------------
# These come from the .env of the build MCP_SERVER_DIR points at — NOT from this
# file. Set them in that build's .env (or export them) to change the log files
# the dashboard reads and its TLS settings. The values below are documentation
# of the expected single-build layout.

# Logging level. One of DEBUG/INFO/WARNING/ERROR.
MQACE_LOG_LEVEL=INFO

# Directory containing query logs. Must match the MCP server's LOG_DIR so the
# dashboard reads the same data the server writes. On RHEL the single build
# defaults to /var/log/mqacemcpserver-single.
LOG_DIR=/var/log/mqacemcpserver-single

# Days to retain rotated log files.
LOG_RETENTION_DAYS=30

# Optional TLS for the dashboard endpoint. Shares certs with the MCP server.
# BOTH cert and key must be set to enable HTTPS; otherwise falls back to HTTP.
# RHEL convention is /etc/pki/tls; a repo-relative ../certs/ dir also works.
MCP_TLS_CERT=/etc/pki/tls/certs/mqacemcpserver.pem
MCP_TLS_KEY=/etc/pki/tls/private/mqacemcpserver.key
