# =============================================================================
# Streamlit chat frontend — environment variables
# Target environment: Linux (Red Hat Enterprise Linux / RHEL 8+, also CentOS
# Stream, Rocky, Alma).
#
# This is the Linux/RHEL variant of .env.example. Copy to `.env` and adjust:
#     cp .env.example.linux .env
# Do NOT commit `.env`.
#
# The Streamlit UI listens on :8003 by default (set via `streamlit run
# --server.port`, not here). Bind ports < 1024 only as root or with
# CAP_NET_BIND_SERVICE.
# =============================================================================

# URL where the chatbot FastAPI backend is reachable.
# The Streamlit app calls /api/health, /api/chat/stream, and /api/chat/reset
# on this base URL.
MCP_BACKEND_URL=http://localhost:8002

# Optional: override the browser tab title (defaults to backend's header_title).
# PAGE_TITLE=

# Optional: override the page icon (any single emoji or unicode glyph).
# PAGE_ICON=
